# Copie este arquivo para .env e preencha com valores reais. O .env nunca deve ser
# versionado (já está no .gitignore).

# --- MongoDB (obrigatório) ---
MONGODB_USERNAME=
MONGODB_PASSWORD=
MONGODB_URI=

# --- Conta de demonstração (opcional) ---
DEMO_ADMIN_USER=admin
DEMO_ADMIN_PASSWORD=

# --- Sessão (opcional; gerado aleatoriamente se ausente) ---
SESSION_SECRET=

# --- Redis (opcional — complementar ao MongoDB: cache das pipelines + estimativa via
# HyperLogLog). Sem esta variável, as 2 funcionalidades de Redis ficam desativadas sem
# quebrar o resto do site. Ex.: redis://127.0.0.1:6379 (local) ou a URL do Upstash/Redis Cloud. ---
REDIS_URL=

# --- Neo4j (opcional — grafo de análise de rede via Graph Data Science). Sem estas 3
# variáveis, o painel de rede fica desativado sem quebrar o resto do site.
# Ex.: NEO4J_URI=bolt://127.0.0.1:7687 ---
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=
